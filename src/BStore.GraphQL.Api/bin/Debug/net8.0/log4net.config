<?xml version="1.0" encoding="utf-8" ?>
<log4net>
  <appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender">
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
    <file value= "./data/default/logs/{yyyy-mm-dd}/Znode_Log.log" />
    <datePattern value="yyyy-MM-dd.'txt'"/>
    <staticLogFileName value="false"/>
    <appendToFile value="true"/>
    <rollingStyle value="Date"/>
    <maxSizeRollBackups value="100"/>
    <maximumFileSize value="15MB"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level App  %newline %message %newline %newline"/>
    </layout>
  </appender>
  <appender name="FileAppender" type="log4net.Appender.FileAppender">
    <file value= "./data/default/logs/{yyyy-mm-dd}/Znode_Log.log" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level App  %newline %message %newline %newline" />
    </layout>
  </appender>

  <appender name='aiAppender' type='Microsoft.ApplicationInsights.Log4NetAppender.ApplicationInsightsAppender, Microsoft.ApplicationInsights.Log4NetAppender'>
    <layout type='log4net.Layout.PatternLayout'>
      <conversionPattern value="%date [%thread] %level %logger.%method[%line] - %message%newline" />
    </layout>
  </appender>

  <appender name="AdoNetAppenderCustom" type="Znode.Libraries.Common.Logger.AdoNetAppenderCustom, Znode.Libraries.Common.Logger" >
    <bufferSize value = '1'/>
    <connectionType value="System.Data.SqlClient.SqlConnection, System.Data.SqlClient, Version=4.6.1.5, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
    <connectionStringName value="Znode_Entities"/>
    <connectionString value = "" />
    <commandText value="INSERT INTO ZnodeActivityLog([ActivityLogTypeId],[portalId],[ActivityCreateDate],[Url],[Data1],[Data2],[Data3],[Status],[LongData],[Source],[Target],[CreatedBy],[CreatedDate],[ModifiedBy],[ModifiedDate]) 
                        VALUES(@ActivityLogTypeId, @portalId,@activityCreateDate, @url, @data1, @data2, @data3, @status,@longData, @source, @target,@createdBy,@createdDate,@modifiedBy,@modifiedDate)" />
    <parameter>
      <parameterName value="@ActivityLogTypeId" />
      <dbType value="Int32" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{activityTypeId}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@portalId" />
      <dbType value="Int32" />
      <size value="255" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{portalId}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@activityCreateDate" />
      <dbType value="DateTime" />
      <layout type="log4net.Layout.RawTimeStampLayout" />
    </parameter>
    <parameter>
      <parameterName value="@createdBy" />
      <dbType value="Int32" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{UserId}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@modifiedBy" />
      <dbType value="Int32" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{UserId}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@createdDate" />
      <dbType value="DateTime" />
      <layout type="log4net.Layout.RawTimeStampLayout" />
    </parameter>
    <parameter>
      <parameterName value="@modifiedDate" />
      <dbType value="DateTime" />
      <layout type="log4net.Layout.RawTimeStampLayout" />
    </parameter>
    <parameter>
      <parameterName value="@data1" />
      <dbType value="String" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{data1}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@data2" />
      <dbType value="String" />
      <size value="255" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{data2}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@data3" />
      <dbType value="String" />
      <size value="4000" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{data3}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@status" />
      <dbType value="String" />
      <size value="2000" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{status}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@longData" />
      <dbType value="String" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{longData}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@source" />
      <dbType value="String" />
      <size value="50" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{source}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@target" />
      <dbType value="String" />
      <size value="255" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{target}" />
      </layout>
    </parameter>
    <parameter>
      <parameterName value="@url" />
      <dbType value="String" />
      <size value="4000" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%property{url}" />
      </layout>
    </parameter>
  </appender>

  <appender name="SmtpAppender" type="log4net.Appender.SmtpAppender">
    <filter type="log4net.Filter.LevelMatchFilter">
      <levelToMatch value="ERROR"/>
    </filter>
    <to value="" />
    <from value="noreply-sendgrid@znode.com" />
    <subject value="Znode Error Log" />
    <smtpHost value="smtp.sendgrid.net" />
    <port value="587"/>
    <username value="apikey"/>
    <authentication value="Basic" />
    <password value="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"/>
    <EnableSsl value="false"/>
    <bufferSize value="1"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%newlineDate - %date{dd MMM yyyy HH:mm:ss}%newlineLevel - %level%newlineUserAgent -  %property{UserAgent}%newlineMessage - %message%newline" />
    </layout>
  </appender>

  <!--element defines the custom appender with the name "CustomMongoDBAppender"/>-->
  <appender name="CustomMongoDBAppender" type="Znode.Libraries.Common.Logger.CustomMongoDBAppender, Znode.Libraries.Common.Logger" >

    <!--element which is used to filter log events based on properties/>-->
    <filter type="log4net.Filter.PropertyFilter">
      <key value="Dblogging" />
      <stringToMatch value="True" />
      <acceptOnMatch value="false" />
    </filter>

    <!--<threshold value="ERROR" />-->
    <!-- MongoDB database connection in the format:
	mongodb://[username:password@]host1[:port1][,host2[:port2],...[,hostN[:portN]]][/[database][?options]]
	See http://www.mongodb.org/display/DOCS/Connections for connectionstring options 
	If no database specified, default to "log4net"-->
    <!-- Name of connectionString defined in web/app.config connectionStrings group, the format is the same as connectionString value.
	Optional, If not provided will use connectionString value-->
    <connectionStringName value="ZnodeMongoDBForLog" />
    <connectionString value=""/>
    <collectionName value="logmessageentity" />

    <!--element specifies the buffer size for the appender./>-->
    <BufferSize value ="3"/>
    <certificateFriendlyName value="Certificate Friendly Name"/>
    <field>
      <name value="LogMessageId" />
      <layout type="log4net.Layout.PatternLayout">
      </layout>
    </field>
    <field>
      <name value="Component" />
      <layout type="log4net.Layout.PatternLayout">
      </layout>
    </field>
    <field>
      <name value="TraceLevel" />
      <layout type="log4net.Layout.PatternLayout" value="%level" />
    </field>
    <field>
      <name value="LogMessage" />
      <layout type="log4net.Layout.PatternLayout" value="%message" />
    </field>
    <field>
      <name value="CreatedDate" />
      <layout type="log4net.Layout.PatternLayout" />
    </field>
    <field>
      <name value="DomainName" />
      <layout type="log4net.Layout.PatternLayout">
      </layout>
    </field>
    <field>
      <name value="StackTraceMessage" />
      <layout type="log4net.Layout.PatternLayout" value="%exception" />
    </field>
  </appender>

  <root>
    <level value="ALL"/>
    <appender-ref ref="BufferingForwardingAppender"/>
  </root>

	<appender name='BufferingForwardingAppender' type='log4net.Appender.BufferingForwardingAppender'>
		<bufferSize value = '50'/>
		<!-- Can add multiple appender-ref to log in batch-->
		<appender-ref ref="CustomMongoDBAppender"/>
		<!--<appender-ref ref="FileAppender"/>
        <appender-ref ref="RollingLogFileAppender"/>
        <appender-ref ref="aiAppender"/>-->
	</appender>
</log4net>