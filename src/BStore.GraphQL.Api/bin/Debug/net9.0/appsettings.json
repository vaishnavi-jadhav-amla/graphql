{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BStoreDownstreamApi": {
    "BaseUrl": "https://localhost:44112/",
    "FileUploadPostPath": "FileUpload/PostAsync",
    "FileUploadRemovePath": "FileUpload/Remove",
    "HttpTimeoutSeconds": 120,
    "ForwardRequestHeaders": [
      "Znode-DomainName",
      "Znode_account",
      "Znode_user",
      "Znode_domain",
      "Znode_portal",
      "Znode_catalog",
      "Znode_locale",
      "Znode_profile",
      "Znode_publishState",
      "Accept-Language",
      "X-Impersonation-Token"
    ]
  },
  "Jwt": {
    "Authority": "",
    "Audience": "",
    "SigningKeyBase64": "",
    "RequireHttpsMetadata": true
  }
}
